# ── Salin fail ini ke .env dan isi nilai sebenar ──────────────
# cp .env.example .env

# PostgreSQL Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_STRONG_PASSWORD_HERE
POSTGRES_DB=perkeso_db
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=5000
DB_SSL=false

# Frontend (URL ke backend - wajib untuk production)
FRONTEND_PORT=3000
VITE_API_URL=http://your-server-ip-or-domain:5000